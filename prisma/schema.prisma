datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String?
  projectType    String
  completionYear Int?
  location       String?
  featured       Boolean  @default(false)
  coverImage     String?
  videoUrl       String?
  technicalSheet String?
  materials      String?
  testimonial    String?
  gallery        String?  // JSON stringified array of URLs
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String?
  fullDescription  String?
  icon             String?
  coverImage       String?
  keyDeliverables  String?  // JSON stringified array of strings
  gallery          String?  // JSON stringified array of URLs
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
